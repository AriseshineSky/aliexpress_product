# Copy this file to .env and fill in real values.
# .env is ignored by git — do NOT commit secrets.

# Elasticsearch — use ES_* or a single ELASTICSEARCH_URL
ES_HOST=34.16.105.219
ES_PORT=9200
ES_USER=your_es_username
ES_PASSWORD=your_es_password
# ELASTICSEARCH_URL=http://your_es_username:your_es_password@34.16.105.219:9200
PRODUCT_INDEX_NAME=user1_aliexpress_us_products

# Elasticsearch URL source index (read product links)
# Index name is fixed in alixq3.py: user1_aliexpress_us_product_urls

# Webshare proxy (browser traffic)
# PROXY_MODE=rotate  — 现有模式：Webshare 网关 + rotate（默认）
# PROXY_MODE=static  — 固定代理列表（data/ 里 host:port:user:pass）
PROXY_MODE=rotate
WEBSHARE_USER=your_webshare_username
WEBSHARE_PASSWORD=your_webshare_password
WEBSHARE_COUNTRY=US
WEBSHARE_HOST=p.webshare.io
WEBSHARE_PORT=80
WEBSHARE_ROTATE=1
# static 模式示例：
# PROXY_MODE=static
# PROXY_FILE=data/Webshare 1000 proxies.txt
# PROXY_INDEX=0
# SESSION_WARMUP=1
# CAPTCHA_KEEP_SESSION=1
# PROXY_MAX_CONSECUTIVE_CAPTCHA=3
# 单代理容量测试：.venv/bin/python scripts/test_one_proxy.py --proxy-index 0

# 反检测：playwright-stealth + 绑定代理的 Canvas/WebGL 指纹池 + 真人鼠标轨迹
# STEALTH_ENABLED=1
# FINGERPRINT_ENABLED=1
# HUMAN_MOUSE_ENABLED=1
# FINGERPRINT_STORE=data/fingerprints.json

# xAI Grok — captcha auto-solve (get key from https://console.x.ai)
XAI_API_KEY=xai-your_api_key_here
# OPENAI_API_KEY=xai-your_api_key_here
OPENAI_MODEL=grok-4.3
OPENAI_API_BASE=https://api.x.ai/v1/chat/completions
CAPTCHA_AUTO_SOLVE=1
# 单次浏览器会话内，验证码最多尝试几轮（每轮：识别 -> 关弹窗 -> 刷新）
# CAPTCHA_RECOVERY_ROUNDS=2
# CAPTCHA_MANUAL_PAUSE_SECONDS=8
# 单个商品验证码失败后，最多硬重启浏览器几次（仅硬失败时清空 profile）
# MAX_CAPTCHA_RESTARTS_PER_URL=2
# 单个商品网络错误页/价格为 0 失败后，本批次最多硬重启几次；超限后留待下次运行重试（不写入 ES）
# MAX_NETWORK_RESTARTS_PER_URL=3
# 硬重启浏览器前等待秒数
# BROWSER_RESTART_DELAY_SECONDS=5
# 确认无法获取商品信息时是否清空 persistent profile（默认 1；成功/下架路径会复用会话）
# CLEAR_PROFILE_ON_HARD_FAIL=1

# Redis 分布式队列（多机同时抓取时启用；密码含特殊字符请 URL 编码）
# REDIS_URL=redis://:password@127.0.0.1:6379/10
# 也兼容旧写法: redis=redis://:...
# REDIS_ROLE=both
# producer=只从 ES 灌队列 | consumer=只消费 | both=灌队列+抓取
# 队列空时是否一直等待新任务（默认 1；设 0 则灌队结束后空闲退出）
# REDIS_WAIT_FOREVER=1
# 队列持续为空时，隔多少秒重新从 ES 扫描并灌入尚未入库的 URL
# REDIS_RESEED_IDLE_SECONDS=60
# REDIS_QUEUE_KEY=alixq3:urls
# REDIS_SEEN_KEY=alixq3:seen
# REDIS_CLAIM_TTL=900

# 并发浏览器窗口数（每个 Worker 独立浏览器 + Webshare 代理连接）
WORKER_COUNT=2
# HEADLESS=0

# 优先抓取：先抓符合列表页指标的商品，完成后再抓其余
# PRIORITY_FIRST=1
# 设为 1 时只抓优先商品，不继续抓其余
# PRIORITY_ONLY=0
# PRIORITY_MAX_PRICE=100
# PRIORITY_MIN_RATING=4.4
# PRIORITY_MIN_REVIEWS=1000
# PRIORITY_MIN_SOLD=1000

# 只抓取 aliexpress.us 商品链接（默认开启）
# CRAWL_US_ONLY=1
# 跳过产品索引里已有 doc 的 URL，专注抓取尚未入库的商品（默认开启）
# SKIP_EXISTING_PRODUCTS=1
# 设为 0 时会更新已有 doc（刷新数据，但 _count 通常不变）
# SKIP_EXISTING_PRODUCTS=0
